# ============================================
# WeiXinSport 安全配置文件示例 (.env.example)
# ============================================
# 重要：在生产环境中，必须修改以下所有值！
# 将此文件复制为 .env 并填写实际值
# ============================================

# -------------------------------
# 数据库配置 (MySQL)
# -------------------------------
# 本地开发使用默认值，生产环境必须修改！
DATABASE_URL=jdbc:mysql://localhost:3306/sportapp
DATABASE_USERNAME=sportapp
DATABASE_PASSWORD=your_secure_database_password_here

# -------------------------------
# Docker Compose 数据库配置
# -------------------------------
# MySQL root 密码（生产环境必须使用强密码）
MYSQL_ROOT_PASSWORD=your_secure_mysql_root_password_here

# -------------------------------
# Redis 配置
# -------------------------------
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_DATABASE=0

# -------------------------------
# JWT 安全配置
# -------------------------------
# 生产环境必须设置强密钥（至少32位随机字符）
# 生成命令：openssl rand -base64 32
JWT_SECRET_KEY=your_secure_jwt_secret_key_min_32_chars_here
JWT_EXPIRE_HOURS=12

# -------------------------------
# 密码加密配置
# -------------------------------
# 密码加密盐值（生产环境必须修改）
PASSWORD_SALT=your_secure_salt_here


# -------------------------------
# 应用配置
# -------------------------------
SERVER_PORT=8080
SPRING_PROFILES_ACTIVE=prod

# -------------------------------
# 安全建议
# -------------------------------
# 1. 数据库：修改所有默认密码，创建独立应用账号（非root）
# 2. JWT：使用强随机密钥，定期轮换
# 3. 密码：使用强密码，定期更换
# 4. 网络：限制数据库和Redis仅内网访问
# 5. 监控：启用日志审计和访问监控

# ============================================
# 使用说明
# ============================================
# Linux/Mac: cp .env.example .env
# Windows: copy .env.example .env
# 然后编辑 .env 文件，修改所有值
#
# 启动应用：docker-compose up -d
#
# 注意：.env 文件包含敏感信息，切勿提交到版本控制系统！
# 建议将 .env 添加到 .gitignore
# ============================================